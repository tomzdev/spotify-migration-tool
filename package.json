{
  "name": "spotify-migration-tool",
  "version": "1.0.0",
  "description": "A web application to migrate playlists, saved tracks, and followed artists between Spotify accounts",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "cd client && npm start",
    "dev:full": "concurrently \"npm run dev\" \"npm run client\"",
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install",
    "postinstall": "npm run install-client",
    "setup": "node setup.js"
  },
  "keywords": [
    "spotify",
    "migration",
    "playlist",
    "music",
    "oauth",
    "react",
    "nodejs",
    "api"
  ],
  "author": "tomzdev <tomzxd.yt@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomzdev/spotify-migration-tool.git"
  },
  "homepage": "https://github.com/tomzdev/spotify-migration-tool#readme",
  "bugs": {
    "url": "https://github.com/tomzdev/spotify-migration-tool/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.1",
    "morgan": "^1.10.0",
    "spotify-web-api-node": "^5.0.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  }
}